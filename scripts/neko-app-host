#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  neko-app-host <app> [options]
  neko-app-host start <app> [options]
  neko-app-host stop [--name NAME]
  neko-app-host status [--name NAME]
  neko-app-host logs [--name NAME] [--tail N]

Examples:
  neko-app-host firefox
  neko-app-host start chromium --port 18080 --udp-range 52000-52100
  neko-app-host status
  neko-app-host logs --tail 80
  neko-app-host stop

Options (start):
  --port N             HTTP port for Neko UI (default: 18080)
  --udp-range A-B      WebRTC UDP range (default: 52000-52100)
  --name NAME          Runtime name (default: neko-host-<app>-<port>)
  --screen WxH@FPS     Neko desktop screen (default: 1920x1080@30)
  --display :N|auto    X display number for Xvfb (default: auto)
  --nat-ip IP|auto     NAT1TO1 IP advertised to clients (default: auto)
  --user-pass PASS     Member/user password (default: neko)
  --admin-pass PASS    Admin password (default: admin)
  --app-cmd CMD        Override app launch command (advanced)
  --dry-run            Print planned commands only

Notes:
  - Host-native mode (no Docker).
  - Requires host deps: Xvfb, openbox, pulseaudio, and built neko binary.
  - Expected neko binary path: ./server/bin/neko (or --neko-bin in script edits).
EOF
}

have_cmd() { command -v "$1" >/dev/null 2>&1; }

is_private_ipv4() {
  local ip="$1"
  [[ "$ip" =~ ^10\. ]] && return 0
  [[ "$ip" =~ ^192\.168\. ]] && return 0
  if [[ "$ip" =~ ^172\.([0-9]+)\. ]]; then
    local octet="${BASH_REMATCH[1]}"
    (( octet >= 16 && octet <= 31 )) && return 0
  fi
  return 1
}

collect_bind_ips() {
  local -n out=$1
  out=()
  while read -r ifname cidr; do
    local ip="${cidr%%/*}"
    [[ "$ip" == 127.* ]] && continue
    if [[ "$ifname" == zt* ]]; then
      out+=("$ip")
      continue
    fi
    if is_private_ipv4 "$ip" && [[ "$ifname" =~ ^(eth|en|wlan|wl|br) ]]; then
      out+=("$ip")
    fi
  done < <(ip -o -4 addr show up scope global 2>/dev/null | awk '{print $2, $4}')

  if [[ ${#out[@]} -eq 0 ]]; then
    for ip in $(hostname -I 2>/dev/null || true); do
      [[ "$ip" == *:* ]] && continue
      [[ "$ip" == 127.* ]] && continue
      if is_private_ipv4 "$ip"; then
        out+=("$ip")
      fi
    done
  fi

  declare -A seen=()
  local -a uniq=()
  for ip in "${out[@]}"; do
    [[ -n "${seen[$ip]:-}" ]] && continue
    seen[$ip]=1
    uniq+=("$ip")
  done
  out=("${uniq[@]}")
}

ensure_x11_socket_dir() {
  local d="/tmp/.X11-unix"
  mkdir -p "$d" 2>/dev/null || true
  chmod 1777 "$d" 2>/dev/null || true
  if [[ ! -w "$d" ]]; then
    cat >&2 <<'EOF'
ERROR: /tmp/.X11-unix is not writable by current user.
Run once:
  sudo mkdir -p /tmp/.X11-unix
  sudo chmod 1777 /tmp/.X11-unix
Then retry.
EOF
    exit 1
  fi
}

pick_display() {
  local n
  for n in $(seq 99 140); do
    if [[ ! -e "/tmp/.X${n}-lock" && ! -S "/tmp/.X11-unix/X${n}" ]]; then
      echo ":${n}"
      return 0
    fi
  done
  echo ":99"
}

is_neko_repo_dir() {
  local d="$1"
  [[ -d "$d/server" && -d "$d/client" ]]
}

repo_root() {
  local script_dir candidate git_root

  # 1) explicit override
  if [[ -n "${NEKO_APP_REPO:-}" ]] && is_neko_repo_dir "$NEKO_APP_REPO"; then
    cd "$NEKO_APP_REPO" && pwd
    return 0
  fi

  # 2) current working directory
  if is_neko_repo_dir "$PWD"; then
    cd "$PWD" && pwd
    return 0
  fi

  # 3) git toplevel from cwd
  if git_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"; then
    if [[ -n "$git_root" ]] && is_neko_repo_dir "$git_root"; then
      cd "$git_root" && pwd
      return 0
    fi
  fi

  # 4) relative to script (works when running from repo checkout)
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  candidate="$(cd "$script_dir/.." && pwd)"
  if is_neko_repo_dir "$candidate"; then
    echo "$candidate"
    return 0
  fi

  cat >&2 <<'EOF'
ERROR: unable to locate Neko repository root.
Run this command inside your cloned neko repo, or set NEKO_APP_REPO=/path/to/neko.
EOF
  exit 1
}

pid_is_alive() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

require_cmd() {
  local c="$1"
  if ! have_cmd "$c"; then
    echo "ERROR: missing required command: $c" >&2
    exit 1
  fi
}

default_app_command() {
  local app="$1"
  case "$app" in
    firefox)
      if have_cmd firefox; then
        echo "$(command -v firefox) --no-remote -P default -width 1280 -height 720"
      elif have_cmd firefox-esr; then
        echo "$(command -v firefox-esr) --no-remote -P default -width 1280 -height 720"
      else
        echo "/usr/bin/firefox --no-remote -P default -width 1280 -height 720"
      fi
      ;;
    chromium)
      if have_cmd chromium; then
        echo "$(command -v chromium) --no-sandbox --no-first-run --start-maximized --disable-gpu --disable-software-rasterizer --disable-dev-shm-usage"
      elif have_cmd chromium-browser; then
        echo "$(command -v chromium-browser) --no-sandbox --no-first-run --start-maximized --disable-gpu --disable-software-rasterizer --disable-dev-shm-usage"
      else
        echo "/usr/bin/chromium --no-sandbox --no-first-run --start-maximized --disable-gpu --disable-software-rasterizer --disable-dev-shm-usage"
      fi
      ;;
    google-chrome|chrome) echo "/usr/bin/google-chrome --no-first-run --start-maximized --disable-gpu --disable-software-rasterizer" ;;
    brave) echo "/usr/bin/brave-browser --no-first-run --start-maximized --disable-gpu --disable-software-rasterizer" ;;
    vivaldi) echo "/usr/bin/vivaldi --no-first-run --start-maximized --disable-gpu --disable-software-rasterizer" ;;
    opera) echo "/usr/bin/opera --no-first-run --start-maximized --disable-gpu --disable-software-rasterizer" ;;
    xfce) echo "/usr/bin/startxfce4" ;;
    kde) echo "/usr/bin/startplasma-x11" ;;
    vlc) echo "/usr/bin/vlc" ;;
    *) echo "$app" ;;
  esac
}

action="start"
if [[ $# -eq 0 ]]; then
  usage
  exit 2
fi

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  start|stop|status|logs)
    action="$1"
    shift
    ;;
  *) action="start" ;;
esac

name=""
port=18080
udp_range="52000-52100"
screen="1920x1080@30"
display="auto"
nat_ip="auto"
user_pass="neko"
admin_pass="admin"
app_cmd_override=""
dry_run=0
tail_lines=200
app=""

if [[ "$action" == "start" ]]; then
  if [[ $# -gt 0 && "${1:0:2}" != "--" ]]; then
    app="$1"
    shift
  fi
  if [[ -z "$app" ]]; then
    echo "ERROR: missing app name (e.g. chromium, firefox, xfce)" >&2
    usage
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="${2:-}"; shift 2 ;;
      --udp-range) udp_range="${2:-}"; shift 2 ;;
      --name) name="${2:-}"; shift 2 ;;
      --screen) screen="${2:-}"; shift 2 ;;
      --display) display="${2:-}"; shift 2 ;;
      --nat-ip) nat_ip="${2:-}"; shift 2 ;;
      --user-pass) user_pass="${2:-}"; shift 2 ;;
      --admin-pass) admin_pass="${2:-}"; shift 2 ;;
      --app-cmd) app_cmd_override="${2:-}"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "ERROR: unknown option: $1" >&2; usage; exit 2 ;;
    esac
  done

  if ! [[ "$port" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
    echo "ERROR: invalid --port: $port" >&2
    exit 2
  fi
  if ! [[ "$udp_range" =~ ^[0-9]+-[0-9]+$ ]]; then
    echo "ERROR: invalid --udp-range: $udp_range" >&2
    exit 2
  fi
  if [[ -z "$name" ]]; then
    name="neko-host-${app}-${port}"
  fi

  if [[ "$display" == "auto" ]]; then
    display="$(pick_display)"
  elif ! [[ "$display" =~ ^:[0-9]+(\.[0-9]+)?$ ]]; then
    echo "ERROR: invalid --display value: $display (use :99 or auto)" >&2
    exit 2
  fi

  IFS='-' read -r udp_start udp_end <<< "$udp_range"
  if (( udp_start < 1024 || udp_end > 65535 || udp_start > udp_end )); then
    echo "ERROR: invalid --udp-range bounds: $udp_range" >&2
    exit 2
  fi

  root="$(repo_root)"
  neko_bin="$root/server/bin/neko"
  static_dir="$root/client/build"
  if [[ ! -d "$static_dir" && -d "$root/client/dist" ]]; then
    static_dir="$root/client/dist"
  fi
  run_root="$root/runs/host"
  state_dir="$run_root/$name"
  pid_file="$state_dir/pids.env"
  mkdir -p "$state_dir/logs"

  local_ips=()
  collect_bind_ips local_ips

  if [[ "$nat_ip" == "auto" ]]; then
    if [[ ${#local_ips[@]} -gt 0 ]]; then
      nat_ip="${local_ips[0]}"
    else
      nat_ip=""
    fi
  fi

  if [[ -n "$app_cmd_override" ]]; then
    app_cmd="$app_cmd_override"
  else
    app_cmd="$(default_app_command "$app")"
  fi

  if (( dry_run == 0 )); then
    require_cmd Xvfb
    require_cmd openbox
    require_cmd pulseaudio
    ensure_x11_socket_dir
    if [[ ! -x "$neko_bin" ]]; then
      cat >&2 <<EOF
ERROR: missing neko binary: $neko_bin
Build it first:
  cd $root/server
  ./build core
EOF
      exit 1
    fi

    cmd_bin="${app_cmd%% *}"
    if [[ ! -x "$cmd_bin" ]] && ! have_cmd "$cmd_bin"; then
      echo "ERROR: app command not found: $cmd_bin" >&2
      echo "Use --app-cmd to override the launch command." >&2
      exit 1
    fi

    if [[ ! -d "$static_dir" ]]; then
      cat >&2 <<EOF
ERROR: missing client static directory (expected client/build or client/dist).
Build it first:
  cd $root/client
  npm install
  npm run build
EOF
      exit 1
    fi
  fi

  pulse_conf="$state_dir/pulse.pa"
  cat > "$pulse_conf" <<EOF
#!/usr/bin/pulseaudio -nF
load-module module-null-sink sink_name=audio_output sink_properties=device.description=Virtual_Audio_Output
load-module module-null-sink sink_name=audio_input sink_properties=device.description=Virtual_Audio_Input
load-module module-virtual-source source_name=microphone master=audio_input.monitor source_properties=device.description=Virtual_Microphone
load-module module-native-protocol-unix socket=$state_dir/pulseaudio.socket auth-anonymous=1
load-module module-always-sink
EOF

  display_num="${display#:}"
  display_num="${display_num%%.*}"

  x_log="$state_dir/logs/xvfb.log"
  pulse_log="$state_dir/logs/pulseaudio.log"
  ob_log="$state_dir/logs/openbox.log"
  app_log="$state_dir/logs/app.log"
  neko_log="$state_dir/logs/neko.log"

  echo "Name: $name"
  echo "Repo: $root"
  echo "Neko: $neko_bin"
  echo "App: $app"
  echo "App command: $app_cmd"
  echo "State dir: $state_dir"
  echo "Display: $display"
  echo "Web port: $port"
  echo "UDP range: $udp_range"
  [[ -n "$nat_ip" ]] && echo "NAT1TO1: $nat_ip"

  if (( dry_run == 1 )); then
    echo "dry-run commands:"
    echo "  Xvfb $display -screen 0 1920x1080x24 -nolisten tcp"
    echo "  pulseaudio -nF $pulse_conf"
    echo "  openbox"
    echo "  $app_cmd"
    echo "  $neko_bin serve --server.bind 0.0.0.0:$port --server.static $static_dir --desktop.display $display --capture.video.display $display --desktop.screen $screen --desktop.input.enabled false --webrtc.epr $udp_start-$udp_end"
  else
    if [[ -f "$pid_file" ]]; then
      # shellcheck disable=SC1090
      source "$pid_file" || true
      if pid_is_alive "${NEKO_PID:-}" || pid_is_alive "${X_PID:-}" || pid_is_alive "${APP_PID:-}"; then
        echo "ERROR: existing runtime appears active. Stop it first:" >&2
        echo "  $0 stop --name $name" >&2
        exit 1
      fi
    fi

    DISPLAY="$display" XDG_RUNTIME_DIR="$state_dir/runtime" HOME="$HOME" \
      Xvfb "$display" -screen 0 1920x1080x24 -nolisten tcp >"$x_log" 2>&1 &
    X_PID=$!

    mkdir -p "$state_dir/runtime"
    chmod 700 "$state_dir/runtime"

    DISPLAY="$display" XDG_RUNTIME_DIR="$state_dir/runtime" HOME="$HOME" \
      pulseaudio -nF "$pulse_conf" --exit-idle-time=-1 >"$pulse_log" 2>&1 &
    PULSE_PID=$!

    DISPLAY="$display" HOME="$HOME" USER="$USER" \
      openbox >"$ob_log" 2>&1 &
    OPENBOX_PID=$!

    DISPLAY="$display" HOME="$HOME" USER="$USER" \
      bash -lc "$app_cmd" >"$app_log" 2>&1 &
    APP_PID=$!

    NEKO_ENV=(
      "DISPLAY=$display"
      "HOME=$HOME"
      "USER=$USER"
      "PULSE_SERVER=unix:$state_dir/pulseaudio.socket"
      "NEKO_MEMBER_PROVIDER=multiuser"
      "NEKO_MEMBER_MULTIUSER_USER_PASSWORD=$user_pass"
      "NEKO_MEMBER_MULTIUSER_ADMIN_PASSWORD=$admin_pass"
      "NEKO_WEBRTC_EPR=$udp_start-$udp_end"
      "NEKO_WEBRTC_ICELITE=1"
      "NEKO_DESKTOP_SCREEN=$screen"
      "NEKO_DESKTOP_INPUT_ENABLED=false"
      "NEKO_DESKTOP_DISPLAY=$display"
      "NEKO_CAPTURE_VIDEO_DISPLAY=$display"
    )
    if [[ -n "$nat_ip" ]]; then
      NEKO_ENV+=("NEKO_WEBRTC_NAT1TO1=$nat_ip")
    fi

    env "${NEKO_ENV[@]}" "$neko_bin" serve \
      --server.bind "0.0.0.0:$port" \
      --server.static "$static_dir" \
      --desktop.display "$display" \
      --capture.video.display "$display" \
      --desktop.screen "$screen" \
      --desktop.input.enabled false \
      --webrtc.epr "$udp_start-$udp_end" >"$neko_log" 2>&1 &
    NEKO_PID=$!

    cat > "$pid_file" <<EOF
NAME=$name
APP=$app
DISPLAY=$display
PORT=$port
UDP_RANGE=$udp_range
STATE_DIR=$state_dir
X_PID=$X_PID
PULSE_PID=$PULSE_PID
OPENBOX_PID=$OPENBOX_PID
APP_PID=$APP_PID
NEKO_PID=$NEKO_PID
EOF
  fi

  echo "URLs:"
  if [[ ${#local_ips[@]} -gt 0 ]]; then
    for ip in "${local_ips[@]}"; do
      echo "  http://${ip}:${port}/"
    done
  else
    echo "  http://127.0.0.1:${port}/"
  fi

  echo "Logs: $state_dir/logs"
  exit 0
fi

root="$(repo_root)"
run_root="$root/runs/host"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name) name="${2:-}"; shift 2 ;;
    --tail) tail_lines="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage; exit 2 ;;
  esac
done

if [[ -z "$name" ]]; then
  name="$(find "$run_root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | head -n1 | xargs -r basename || true)"
fi

if [[ -z "$name" ]]; then
  echo "ERROR: no host runtime selected. Use --name <name>." >&2
  exit 1
fi

state_dir="$run_root/$name"
pid_file="$state_dir/pids.env"

if [[ ! -f "$pid_file" ]]; then
  echo "ERROR: runtime state not found: $pid_file" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$pid_file"

case "$action" in
  stop)
    for p in "${NEKO_PID:-}" "${APP_PID:-}" "${OPENBOX_PID:-}" "${PULSE_PID:-}" "${X_PID:-}"; do
      if pid_is_alive "$p"; then
        kill "$p" 2>/dev/null || true
      fi
    done
    sleep 1
    for p in "${NEKO_PID:-}" "${APP_PID:-}" "${OPENBOX_PID:-}" "${PULSE_PID:-}" "${X_PID:-}"; do
      if pid_is_alive "$p"; then
        kill -9 "$p" 2>/dev/null || true
      fi
    done
    echo "Stopped runtime: $name"
    ;;
  status)
    echo "Name: ${NAME:-$name}"
    echo "State dir: $state_dir"
    for label in X_PID PULSE_PID OPENBOX_PID APP_PID NEKO_PID; do
      pid="${!label:-}"
      if pid_is_alive "$pid"; then
        echo "  $label: $pid (running)"
      else
        echo "  $label: ${pid:-n/a} (stopped)"
      fi
    done
    ;;
  logs)
    for f in "$state_dir"/logs/*.log; do
      [[ -f "$f" ]] || continue
      echo "==> $f <=="
      tail -n "$tail_lines" "$f" || true
      echo
    done
    ;;
esac
